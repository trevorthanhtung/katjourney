rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getShare(token) {
      return get(/databases/$(database)/documents/publicShares/$(token)).data;
    }

    function isShareOwner(token) {
      return isAuthenticated() && getShare(token).ownerUid == request.auth.uid;
    }

    function isShareEditable(token) {
      return getShare(token).mode == 'edit';
    }

    function isShareRequestable(token) {
      return getShare(token).mode == 'edit' || getShare(token).mode == 'request_edit';
    }

    // 1. Users collection (Private backups)
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // backups subcollection
      match /backups/{backupId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Public Shares collection
    match /publicShares/{token} {
      // Anyone can read a public share if it's not revoked
      allow read: if resource == null || resource.data.revoked == false;
      
      // Creating a share link: must be signed in, and set themselves as the owner
      allow create: if isAuthenticated() 
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.token == token
                    && request.resource.data.mode is string;
      
      // Updating/Deleting: only the owner, OR collaborators if it's in edit mode (for trip.dayRoadmaps updates)
      allow update: if isShareOwner(token) || (resource.data.revoked == false && isShareEditable(token));
      allow delete: if isShareOwner(token);

      // Subcollections of publicShares
      match /{subcollection}/{docId} {
        // Members, activities, expenses, checklist, journals, backupPlans, travelDocuments
        allow read: if getShare(token).revoked == false;
        
        // Write: allowed if owner, OR if the share is in 'edit' mode (direct collaborator edits)
        allow create, update, delete: if isShareOwner(token) || (getShare(token).revoked == false && isShareEditable(token));
      }

      // changeRequests subcollection
      match /changeRequests/{requestId} {
        // Owner of the share can read and update (approve) requests
        // Collaborators can submit (create) requests if the mode allows it
        allow read: if isShareOwner(token);
        allow create: if getShare(token).revoked == false 
                      && isShareRequestable(token) 
                      && request.resource.data.requesterUid == request.auth.uid
                      && request.resource.data.section is string
                      && request.resource.data.action is string
                      && (request.resource.data.note == null || (request.resource.data.note is string && request.resource.data.note.size() < 500));
        allow update: if isShareOwner(token) && request.resource.data.status in ['approved', 'rejected', 'pending'];
        allow delete: if isShareOwner(token);
      }
    }

    // 3. Collaborative Chats
    match /chats/{token} {
      allow read: if getShare(token).revoked == false;

      match /messages/{messageId} {
        allow read: if getShare(token).revoked == false;
        allow create: if getShare(token).revoked == false 
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text is string 
                      && request.resource.data.text.size() < 1000
                      && request.resource.data.senderName is string
                      && request.resource.data.senderName.size() < 100;
        allow update, delete: if false; // Chats are append-only for simplicity/integrity
      }
    }
  }
}
